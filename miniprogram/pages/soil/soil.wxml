<view class="container">
  <view class="card">
    <view class="card-header">
      <view>
        <text class="card-title">🌍 土壤数据管理</text>
        <text class="card-subtitle">定点定深测量数据</text>
      </view>
      <button class="btn btn-primary" bindtap="showAddModal">添加数据</button>
    </view>
    
    <view class="data-list">
      <view wx:for="{{soilData}}" wx:key="_id" class="data-item" style="flex-direction:column;align-items:flex-start;">
        <view style="display:flex;justify-content:space-between;width:100%;margin-bottom:12rpx;">
          <text class="data-label">{{item.displayTime}}</text>
          <text class="warning-badge {{item.quality}}">{{item.qualityText}}</text>
        </view>
        <view style="display:flex;flex-wrap:wrap;gap:30rpx;">
          <view>
            <text class="data-label">位置：</text>
            <text class="data-value">{{item.displayLocation}}</text>
          </view>
          <view>
            <text class="data-label">深度：</text>
            <text class="data-value">{{item.depth}}cm</text>
          </view>
          <view>
            <text class="data-label">湿度：</text>
            <text class="data-value">{{item.moisture}}%</text>
          </view>
          <view>
            <text class="data-label">温度：</text>
            <text class="data-value">{{item.temperature}}°C</text>
          </view>
          <view>
            <text class="data-label">电导率：</text>
            <text class="data-value">{{item.conductivity}} mS/cm</text>
          </view>
          <view wx:if="{{item.ph}}">
            <text class="data-label">pH：</text>
            <text class="data-value">{{item.ph}}</text>
          </view>
        </view>
        <view style="margin-top:12rpx;">
          <button class="btn btn-secondary" style="font-size:24rpx;padding:12rpx 24rpx;" bindtap="deleteData" data-id="{{item._id}}">删除</button>
        </view>
      </view>
    </view>
    
    <view wx:if="{{!soilData.length}}" class="loading">
      <text class="loading-text">暂无数据</text>
    </view>
  </view>

  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="hideModal">
    <view class="modal-content" bindtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">添加土壤数据</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      
      <view class="form-group">
        <text class="form-label">纬度</text>
        <input class="form-control" type="digit" placeholder="请输入纬度" value="{{newData.location.latitude}}" bindinput="onInput" data-field="latitude"/>
      </view>
      <view class="form-group">
        <text class="form-label">经度</text>
        <input class="form-control" type="digit" placeholder="请输入经度" value="{{newData.location.longitude}}" bindinput="onInput" data-field="longitude"/>
      </view>
      <view class="form-group">
        <text class="form-label">测量深度(cm)</text>
        <input class="form-control" type="number" placeholder="请输入深度" value="{{newData.depth}}" bindinput="onInput" data-field="depth"/>
      </view>
      <view class="form-group">
        <text class="form-label">土壤湿度(%)</text>
        <input class="form-control" type="number" placeholder="请输入湿度" value="{{newData.moisture}}" bindinput="onInput" data-field="moisture"/>
      </view>
      <view class="form-group">
        <text class="form-label">土壤温度(°C)</text>
        <input class="form-control" type="digit" placeholder="请输入温度" value="{{newData.temperature}}" bindinput="onInput" data-field="temperature"/>
      </view>
      <view class="form-group">
        <text class="form-label">电导率(mS/cm)</text>
        <input class="form-control" type="digit" placeholder="请输入电导率" value="{{newData.conductivity}}" bindinput="onInput" data-field="conductivity"/>
      </view>
      
      <button class="btn btn-primary" style="width:100%;" bindtap="submitData">提交</button>
    </view>
  </view>
</view>