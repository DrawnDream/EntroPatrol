page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.swiper-container {
  width: 100%;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.swiper-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.swiper-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}

.swiper-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.swiper-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
}

.container {
  padding: 20rpx;
}

.card {
  background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(224, 235, 225, 0.5);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-subtitle {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(224, 235, 225, 0.4);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2E7D32;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

.btn {
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(46, 125, 50, 0.4);
}

.btn-secondary {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  color: #475569;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(224, 235, 225, 0.6);
}

.btn-secondary:active {
  transform: scale(0.98);
}

.warning-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.warning-badge.severe {
  background-color: #ffebee;
  color: #c62828;
}

.warning-badge.warning {
  background-color: #fff3e0;
  color: #ef6c00;
}

.warning-badge.caution {
  background-color: #fff9c4;
  color: #f9a825;
}

.warning-badge.normal {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.health-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.health-badge.healthy {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.health-badge.moderate {
  background-color: #fff9c4;
  color: #f9a825;
}

.health-badge.poor {
  background-color: #ffebee;
  color: #c62828;
}

.data-list {
  padding: 0;
  margin: 0;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.data-item:last-child {
  border-bottom: none;
}

.data-label {
  font-size: 28rpx;
  color: #666666;
}

.data-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.modal-content {
  background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 92%;
  max-height: 85vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(40rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-control {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-control:focus {
  border-color: #2E7D32;
  outline: none;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #2E7D32;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666666;
}

.ai-response {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 24rpx;
  white-space: pre-wrap;
  font-size: 28rpx;
  line-height: 1.8;
  max-height: 600rpx;
  overflow-y: auto;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #f0f4f8;
  color: #666666;
}

.tab-item.active {
  background-color: #2E7D32;
  color: #ffffff;
}